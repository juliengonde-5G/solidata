# ============================================
# Solidata — Configuration environnement
# ============================================
# Copier ce fichier vers .env et remplir les valeurs :
#   cp .env.example .env
#
# Générer les secrets :
#   openssl rand -base64 32   (pour POSTGRES_PASSWORD)
#   openssl rand -base64 48   (pour JWT_SECRET)
# ============================================

# --- Base de données ---
POSTGRES_USER=solidata
POSTGRES_PASSWORD=CHANGEZ_MOI
POSTGRES_DB=solidata

# --- Backend ---
DATABASE_URL=postgresql+asyncpg://solidata:CHANGEZ_MOI@db:5432/solidata
JWT_SECRET=CHANGEZ_MOI_AUSSI
CORS_ORIGINS=https://solidata.online,https://www.solidata.online

# --- Domaine (utilisé par nginx et certbot) ---
DOMAIN=solidata.online
