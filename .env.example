# ==============================================
# Solidata - Variables d'environnement
# ==============================================
# Copier ce fichier en .env et adapter les valeurs
# cp .env.example .env
# ==============================================

# --- Base de donnees PostgreSQL ---
# Mot de passe de la base (utilise par les services db et backend)
DB_PASSWORD=solidata_secret_2026

# --- Authentification JWT ---
# Secret pour la signature des tokens (changer en production !)
JWT_SECRET=solidata_jwt_secret_2026

# --- Configuration email (IMAP) ---
# Utilise pour l'aspiration automatique des CV recus par email
# et l'envoi d'emails (rejet, lettre de recrutement)
MAIL_HOST=imap.example.com
MAIL_PORT=993
MAIL_USER=recrutement@solidarite-textiles.fr
MAIL_PASSWORD=your_mail_password
MAIL_TLS=true

# --- Port d'exposition (optionnel) ---
# Modifier dans docker-compose.yml si le port 8083 est deja utilise
# Par defaut : 8083

# --- Configuration SMS (a venir) ---
# Pour l'envoi de SMS de convocation aux candidats
# SMS_PROVIDER=ovh
# SMS_API_KEY=
# SMS_API_SECRET=
# SMS_SENDER=SolTextiles

# --- Google Maps (optionnel) ---
# Cle API pour l'affichage de cartes embarquees dans l'app mobile
# GOOGLE_MAPS_API_KEY=AIzaSy...
